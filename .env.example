# Cloudflare Tunnel token
# Hent fra: Cloudflare Zero Trust → Networks → Tunnels → din tunnel → Configure → token
CLOUDFLARE_TUNNEL_TOKEN=ditt-token-her

# Passord for web-grensesnittet (valgfritt — uten dette er dashboardet åpent)
GEOLOOP_PASSWORD=ditt-passord-her

# ntfy-server og topics
NTFY_URL=https://ntfy.tommytv.no
NTFY_TOPIC=geoloop-21a

# Watchdog bruker ntfy.sh (ikke lokal server — den er nede hvis hovedserveren er nede)
WATCHDOG_NTFY_TOPIC=tommytv-uptime
